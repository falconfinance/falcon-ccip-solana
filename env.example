# =============================================================================
# Falcon CCIP - Add Solana Chain Configuration
# =============================================================================
# Copy this file to the project root as .env and fill in the values.
#
# cp script/env.example .env
# =============================================================================

# ------------- Network Configuration -------------

# Solana network: "devnet" or "mainnet-beta"
SOLANA_NETWORK=devnet

# EVM network name (Hardhat network name)
# Testnet:  ethereumSepolia
# Mainnet:  mainnet
EVM_NETWORK=ethereumSepolia

# EVM chain ID
# Ethereum Sepolia: 11155111
# Ethereum Mainnet: 1
EVM_CHAIN_ID=11155111

# Remote chain name used in Solana CCIP scripts
# Testnet:  ethereum-sepolia
# Mainnet:  ethereum-mainnet
REMOTE_CHAIN_NAME=ethereum-sepolia

# ------------- EVM Configuration -------------

# EVM RPC URL
EVM_RPC_URL=https://eth-sepolia.api.onfinality.io/public

# EVM private key (with 0x prefix)
EVM_PRIVATE_KEY=0x...

# Existing EVM token address (already deployed via falconCCIP)
EVM_TOKEN_ADDRESS=0x...

# Existing EVM pool address (already deployed via falconCCIP)
EVM_POOL_ADDRESS=0x...

# ------------- EVM Tooling Paths -------------

# Path to Hardhat project (for testnet direct execution)
# Used by e2eAddSolanaTestnet.sh
EVM_HARDHAT_DIR=/path/to/smart-contract-examples/ccip/cct/hardhat

# Path to falconCCIP project (for mainnet MULTISIG operations)
# Used by e2eAddSolanaMainnet.sh
FALCON_CCIP_DIR=/path/to/falconCCIP

# ------------- Token Configuration -------------

# Solana SPL token name, symbol, and decimals
TOKEN_NAME="Falcon USD"
TOKEN_SYMBOL="USDf"
TOKEN_DECIMALS=9

# EVM token decimals (CRITICAL: used for cross-chain decimal conversion)
# This tells the Solana pool how many decimals the REMOTE EVM token has.
# Must match the actual EVM token decimals to avoid incorrect minting amounts.
EVM_TOKEN_DECIMALS=18

# CCIP BurnMint Pool Program ID
# Solana Devnet:  41FGToCmdaWa1dgZLKFAjvmx6e6AjVTX7SVRibvsMGVB
# Solana Mainnet: (check CCIP Directory)
CCIP_POOL_PROGRAM=41FGToCmdaWa1dgZLKFAjvmx6e6AjVTX7SVRibvsMGVB

# ------------- Multisig (Mainnet REQUIRED) -------------

# Squads Protocol multisig address
# Required for e2eAddSolanaMainnet.sh
# Leave empty for testnet
SQUADS_MULTISIG_ADDRESS=
